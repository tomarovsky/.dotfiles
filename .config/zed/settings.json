// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette

{
    "telemetry": { "diagnostics": true, "metrics": false },
    "theme": {
        "mode": "dark",
        "light": "Gruvbox Dark Hard",
        "dark": "Gruvbox Dark Hard",
    },
    "soft_wrap": "editor_width",
    "buffer_font_family": "JetBrains Mono",
    "buffer_font_size": 15,
    "ui_font_family": "JetBrains Mono",
    "ui_font_size": 15,
    "current_line_highlight": "all",
    "autosave": "on_focus_change",

    "edit_predictions": {
        "disabled_globs": [
            "**/.git",
            "**/.snakemake",
            "**/.vscode",
            "**/.idea",
            "**/.venv",
            "**/__pycache__",
            "**/.ruff_cache",
        ],
    },
    // "agent": {
    //     "default_profile": "ask",
    //     "default_model": {
    //         "provider": "zed.dev",
    //         "model": "claude-3-7-sonnet-latest",
    //     },
    // },
    "show_edit_predictions": true,
    "file_types": {
        "Snakemake": ["Snakefile", "*.smk"],
        "Dockerfile": ["Dockerfile", "Dockerfile.*"],
        "JSON": ["json", "jsonc", "*.code-snippets"],
        "Git Attributes": ["**/{git,.git/info}/attributes"],
        "Git Config": [
            "*.gitconfig",
            "**/{git,.git/modules,.git/modules/*}/config",
        ],
        "Git Ignore": ["**/{git,.git}/ignore", "**/.git/info/exclude"],
    },
    "languages": {
        "Python": {
            "language_servers": ["ruff", "basedpyright", "!pyright"],
            "format_on_save": "off",
            "formatter": {
                "language_server": {
                    "name": "ruff",
                },
            },
        },
        "Shell Script": {
            "format_on_save": "off",
            "formatter": {
                "external": {
                    "command": "shfmt",
                    "arguments": [
                        "--filename",
                        "{buffer_path}",
                        "--indent",
                        "4",
                    ],
                },
            },
        },
    },
    "lsp": {
        "basedpyright": {
            "settings": {
                "python": {
                    "pythonPath": "./.venv/bin/python",
                },
                "basedpyright.analysis": {
                    "diagnosticMode": "workspace",
                    "inlayHints": {
                        "callArgumentNames": false,
                    },
                },
            },
        },
        "ruff": {
            "initialization_options": {
                "settings": {
                    "lineLength": 150,
                },
            },
        },
    },
    "tab_size": 4,
    "scrollbar": { "show": "never" },
    "tabs": {
        "file_icons": true,
        "git_status": true,
    },
    "terminal": {
        "copy_on_select": true,
        "font_family": "JetBrains Mono",
        "detect_venv": {
            "on": {
                "directories": [".venv", "venv"],
                "activate_script": "default",
            },
        },
    },
    "file_scan_exclusions": [
        "**/.git",
        "**/.vscode",
        "**/.idea",
        "**/.venv",
        "**/__pycache__",
        "**/.ruff_cache",
    ],
    "file_scan_inclusions": [".env"],
    "project_panel": {
        "default_width": 300,
        "dock": "left",
        "file_icons": true,
        "folder_icons": true,
        "git_status": true,
        "scrollbar": {
            "show": "never",
        },
    },

    "use_smartcase_search": true,
    "search": {
        "whole_word": false,
        "case_sensitive": true,
        "include_ignored": false,
        "regex": false,
    },
    "lsp_document_colors": "background",
    "vim_mode": true,
    "vim": {
        "use_system_clipboard": "always",
        "highlight_on_yank_duration": 50,
        "use_smartcase_find": true,
    },

    "which_key": { "enabled": true },
}
